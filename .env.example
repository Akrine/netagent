# Anthropic API key - required for agent reasoning
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Network Weather Partner API credentials
NWX_CLIENT_ID=your_client_id_here
NWX_CLIENT_SECRET=your_client_secret_here

# Monday.com personal API token
# Get from: monday.com > Profile > Admin > API
MONDAY_API_TOKEN=your_monday_api_token_here
